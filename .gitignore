# Tiroirs médias — gardés localement, pas en dépôt.
# (Les manifest.json/.js sont régénérés à chaque lancement par start.bat
#  ou `python scripts/gen_manifests.py`, donc inutile de les versionner.)
images/*
!images/.gitkeep
videos/*
!videos/.gitkeep
musiques/*
!musiques/.gitkeep
texturegif/*
!texturegif/.gitkeep
!texturegif/mur/
!texturegif/plafond/
!texturegif/sol/
texturegif/mur/*
!texturegif/mur/.gitkeep
texturegif/plafond/*
!texturegif/plafond/.gitkeep
texturegif/sol/*
!texturegif/sol/.gitkeep
